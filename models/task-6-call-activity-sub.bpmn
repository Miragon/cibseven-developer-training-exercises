  <bpmn:process id="handleRejection" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="startEvent_confirmationRejected" name="Confirmation rejected">
      <bpmn:outgoing>Flow_0vqwqsj</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:businessRuleTask id="serviceTask_categorizeApplicant" name="Categorize applicant" camunda:decisionRef="categorizeApplicant" camunda:mapDecisionResult="singleEntry" camunda:resultVariable="isHighValue">
      <bpmn:incoming>Flow_0vqwqsj</bpmn:incoming>
      <bpmn:outgoing>Flow_0gvf8zj</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:sequenceFlow id="Flow_0vqwqsj" sourceRef="startEvent_confirmationRejected" targetRef="serviceTask_categorizeApplicant" />
    <bpmn:exclusiveGateway id="gateway_highValue" name="High value?" default="Flow_1imjd1v">
      <bpmn:incoming>Flow_0gvf8zj</bpmn:incoming>
      <bpmn:outgoing>Flow_07y997b</bpmn:outgoing>
      <bpmn:outgoing>Flow_1imjd1v</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0gvf8zj" sourceRef="serviceTask_categorizeApplicant" targetRef="gateway_highValue" />
    <bpmn:sequenceFlow id="Flow_07y997b" sourceRef="gateway_highValue" targetRef="userTask_writeRegretMail">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isHighValue}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="userTask_writeRegretMail" name="Write an&#10;email expressing regret">
      <bpmn:incoming>Flow_07y997b</bpmn:incoming>
      <bpmn:outgoing>Flow_1ufk6o2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="endEvent_triedToReacquire" name="Tried to reaquire applicant">
      <bpmn:incoming>Flow_1ufk6o2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1ufk6o2" sourceRef="userTask_writeRegretMail" targetRef="endEvent_triedToReacquire" />
    <bpmn:endEvent id="endEvent_acceptRejection" name="Accept rejection">
      <bpmn:incoming>Flow_1imjd1v</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1imjd1v" sourceRef="gateway_highValue" targetRef="endEvent_acceptRejection" />
  </bpmn:process>
