<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1d2hcmz" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.20.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:process id="subscribeNewsletter" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="startEvent_submitRegistration" name="Submit registration form" camunda:asyncBefore="true">
      <bpmn:outgoing>Flow_0p7ko1g</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0rxlo7x" messageRef="Message_3p5jpc1" />
    </bpmn:startEvent>
    <bpmn:subProcess id="subProcess_confirmMembership" name="Confirm membership">
      <bpmn:incoming>Flow_0camehw</bpmn:incoming>
      <bpmn:outgoing>Flow_1j9l21y</bpmn:outgoing>
      <bpmn:startEvent id="startEvent_confirmationRequired" name="Confirmation required">
        <bpmn:outgoing>Flow_1y9mu7r</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="serviceTask_sendConfirmationMail" name="Send confirmation mail" camunda:delegateExpression="#{sendConfirmationMailDelegate}">
        <bpmn:incoming>Flow_1y9mu7r</bpmn:incoming>
        <bpmn:outgoing>Flow_1wb7scj</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:userTask id="userTask_confirmMembership" name="Confirm membership" camunda:asyncAfter="true">
        <bpmn:incoming>Flow_1wb7scj</bpmn:incoming>
        <bpmn:outgoing>Flow_0w9368p</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:endEvent id="endEvent_membershipConfirmed" name="Membership confirmed">
        <bpmn:incoming>Flow_0w9368p</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_1y9mu7r" sourceRef="startEvent_confirmationRequired" targetRef="serviceTask_sendConfirmationMail" />
      <bpmn:sequenceFlow id="Flow_1wb7scj" sourceRef="serviceTask_sendConfirmationMail" targetRef="userTask_confirmMembership" />
      <bpmn:sequenceFlow id="Flow_0w9368p" sourceRef="userTask_confirmMembership" targetRef="endEvent_membershipConfirmed" />
    </bpmn:subProcess>
    <bpmn:serviceTask id="serviceTask_sendWelcomeMail" name="Send Welcome Mail" camunda:delegateExpression="#{sendWelcomeMailDelegate}">
      <bpmn:incoming>Flow_1j9l21y</bpmn:incoming>
      <bpmn:outgoing>Flow_14bk7y3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="serviceTask_claimMembership" name="Claim membership" camunda:delegateExpression="#{claimMembershipDelegate}">
      <bpmn:incoming>Flow_0p7ko1g</bpmn:incoming>
      <bpmn:outgoing>Flow_0hlnr3k</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_hasEmptySpots" name="Has empty spots" default="Flow_0camehw">
      <bpmn:incoming>Flow_0hlnr3k</bpmn:incoming>
      <bpmn:outgoing>Flow_0camehw</bpmn:outgoing>
      <bpmn:outgoing>Flow_0bt3531</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="endEvent_membershipRejected" name="Membership rejected">
      <bpmn:incoming>Flow_10ryvaz</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="serviceTask_sendRejectionMail" name="Send rejection mail" camunda:delegateExpression="#{sendRejectionMailDelegate}">
      <bpmn:incoming>Flow_0bt3531</bpmn:incoming>
      <bpmn:outgoing>Flow_10ryvaz</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="serviceTask_reSendConfirmationMail" name="Re-Send confirmation mail" camunda:delegateExpression="#{reSendConfirmationMailDelegate}">
      <bpmn:incoming>Flow_1unns5i</bpmn:incoming>
      <bpmn:outgoing>Flow_03vzvil</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="endEvent_mailSentAgain" name="Mail sent again">
      <bpmn:incoming>Flow_03vzvil</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="endEvent_membershipActivated" name="Membership activated">
      <bpmn:incoming>Flow_14bk7y3</bpmn:incoming>
      <bpmn:signalEventDefinition id="SignalEventDefinition_0qglo4a" signalRef="Signal_membershipActivated" />
    </bpmn:endEvent>
    <bpmn:startEvent id="startEvent_membershipActivated" name="Membership activated" camunda:asyncBefore="true">
      <bpmn:outgoing>Flow_0ayt3tk</bpmn:outgoing>
      <bpmn:signalEventDefinition id="SignalEventDefinition_0q6ianv" signalRef="Signal_membershipActivated" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="serviceTask_publishSignal" name="Publish message in forum" camunda:delegateExpression="#{notifyAboutSignedMembershipDelegate}">
      <bpmn:incoming>Flow_0ayt3tk</bpmn:incoming>
      <bpmn:outgoing>Flow_1xadvxb</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0ayt3tk" sourceRef="startEvent_membershipActivated" targetRef="serviceTask_publishSignal" />
    <bpmn:serviceTask id="serviceTask_revokeClaim" name="Revoke claim" isForCompensation="true" camunda:delegateExpression="#{revokeClaimDelegate}" />
    <bpmn:boundaryEvent id="boundary_compensateClaim" attachedToRef="serviceTask_claimMembership">
      <bpmn:compensateEventDefinition id="CompensateEventDefinition_claim" />
    </bpmn:boundaryEvent>
    <bpmn:association id="association_compensateClaim" associationDirection="One" sourceRef="boundary_compensateClaim" targetRef="serviceTask_revokeClaim" />
    <bpmn:endEvent id="endEvent_membershipDeclined" name="Membership declined">
      <bpmn:incoming>Flow_0ho2dhw</bpmn:incoming>
      <bpmn:incoming>Flow_153mcrs</bpmn:incoming>
      <bpmn:compensateEventDefinition id="CompensateEventDefinition_declined" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0ho2dhw" sourceRef="timer_abortAfter3HalfDays" targetRef="endEvent_membershipDeclined" />
    <bpmn:sequenceFlow id="Flow_153mcrs" sourceRef="event_confirmationRejected" targetRef="endEvent_membershipDeclined" />
    <bpmn:boundaryEvent id="timer_abortAfter3HalfDays" name="After 3&#10;1/2 days" attachedToRef="subProcess_confirmMembership" camunda:asyncAfter="true">
      <bpmn:outgoing>Flow_0ho2dhw</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1ipk14c">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3DT12H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="event_confirmationRejected" name="Confirmation rejected" attachedToRef="subProcess_confirmMembership" camunda:asyncAfter="true">
      <bpmn:outgoing>Flow_153mcrs</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0po7vrz" messageRef="Message_ConfirmationRejected" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="timer_resendEveryDay" name="Every day" cancelActivity="false" attachedToRef="subProcess_confirmMembership" camunda:asyncAfter="true">
      <bpmn:outgoing>Flow_1unns5i</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1f4kmf0">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P1D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_14bk7y3" sourceRef="serviceTask_sendWelcomeMail" targetRef="endEvent_membershipActivated" />
    <bpmn:sequenceFlow id="Flow_0p7ko1g" sourceRef="startEvent_submitRegistration" targetRef="serviceTask_claimMembership" />
    <bpmn:sequenceFlow id="Flow_0camehw" name="Yes" sourceRef="gateway_hasEmptySpots" targetRef="subProcess_confirmMembership" />
    <bpmn:sequenceFlow id="Flow_1j9l21y" sourceRef="subProcess_confirmMembership" targetRef="serviceTask_sendWelcomeMail" />
    <bpmn:sequenceFlow id="Flow_0hlnr3k" sourceRef="serviceTask_claimMembership" targetRef="gateway_hasEmptySpots" />
    <bpmn:sequenceFlow id="Flow_0bt3531" name="No" sourceRef="gateway_hasEmptySpots" targetRef="serviceTask_sendRejectionMail">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!hasEmptySpots}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_10ryvaz" sourceRef="serviceTask_sendRejectionMail" targetRef="endEvent_membershipRejected" />
    <bpmn:sequenceFlow id="Flow_1unns5i" sourceRef="timer_resendEveryDay" targetRef="serviceTask_reSendConfirmationMail" />
    <bpmn:sequenceFlow id="Flow_03vzvil" sourceRef="serviceTask_reSendConfirmationMail" targetRef="endEvent_mailSentAgain" />
    <bpmn:endEvent id="endEvent_notificationSent" name="Notification sent">
      <bpmn:incoming>Flow_1xadvxb</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1xadvxb" sourceRef="serviceTask_publishSignal" targetRef="endEvent_notificationSent" />
  </bpmn:process>
  <bpmn:message id="Message_3p5jpc1" name="Message_SubscriptionRequested" />
  <bpmn:message id="Message_ConfirmationRejected" name="Message_ConfirmationRejected" />
  <bpmn:signal id="Signal_membershipActivated" name="signal_membershipActivated" />
