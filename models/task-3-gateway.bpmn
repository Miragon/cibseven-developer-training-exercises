  <bpmn:process id="subscribeNewsletter" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="startEvent_submitRegistration" name="Submit registration form">
      <bpmn:outgoing>Flow_0p7ko1g</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0p7ko1g" sourceRef="startEvent_submitRegistration" targetRef="serviceTask_claimMembership" />
    <bpmn:sequenceFlow id="Flow_0ya530i" sourceRef="userTask_confirmMembership" targetRef="serviceTask_sendWelcomeMail" />
    <bpmn:userTask id="userTask_confirmMembership" name="Confirm membership">
      <bpmn:incoming>Flow_13584xc</bpmn:incoming>
      <bpmn:outgoing>Flow_0ya530i</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="serviceTask_sendWelcomeMail" name="Send Welcome Mail" camunda:type="external" camunda:topic="membership.sendWelcomeMail">
      <bpmn:incoming>Flow_0ya530i</bpmn:incoming>
      <bpmn:outgoing>Flow_1s74azu</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="endEvent_membershipConfirmed" name="Membership confirmed">
      <bpmn:incoming>Flow_1s74azu</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1s74azu" sourceRef="serviceTask_sendWelcomeMail" targetRef="endEvent_membershipConfirmed" />
    <bpmn:sequenceFlow id="Flow_13584xc" sourceRef="serviceTask_sendConfirmationMail" targetRef="userTask_confirmMembership" />
    <bpmn:serviceTask id="serviceTask_sendConfirmationMail" name="Send confirmation mail" camunda:type="external" camunda:topic="membership.sendConfirmationMail">
      <bpmn:incoming>Flow_1pl6nn4</bpmn:incoming>
      <bpmn:outgoing>Flow_13584xc</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1spthma" sourceRef="serviceTask_claimMembership" targetRef="gateway_hasEmptySpots" />
    <bpmn:serviceTask id="serviceTask_claimMembership" name="Claim membership" camunda:type="external" camunda:topic="membership.claimMembership">
      <bpmn:incoming>Flow_0p7ko1g</bpmn:incoming>
      <bpmn:outgoing>Flow_1spthma</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_hasEmptySpots" name="Has empty spots" default="Flow_1pl6nn4">
      <bpmn:incoming>Flow_1spthma</bpmn:incoming>
      <bpmn:outgoing>Flow_1pl6nn4</bpmn:outgoing>
      <bpmn:outgoing>Flow_0cad0i8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1pl6nn4" name="Yes" sourceRef="gateway_hasEmptySpots" targetRef="serviceTask_sendConfirmationMail" />
    <bpmn:serviceTask id="serviceTask_sendRejectionMail" name="Send rejection mail" camunda:type="external" camunda:topic="membership.sendRejectionMail">
      <bpmn:incoming>Flow_0cad0i8</bpmn:incoming>
      <bpmn:outgoing>Flow_0loiw0z</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0cad0i8" name="No" sourceRef="gateway_hasEmptySpots" targetRef="serviceTask_sendRejectionMail">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!hasEmptySpots}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="endEvent_membershipRejected" name="Membership rejected">
      <bpmn:incoming>Flow_0loiw0z</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0loiw0z" sourceRef="serviceTask_sendRejectionMail" targetRef="endEvent_membershipRejected" />
  </bpmn:process>
