<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
                  id="Definitions_rejection"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.20.0"
                  modeler:executionPlatform="Camunda Platform"
                  modeler:executionPlatformVersion="7.24.0">

  <bpmn:process id="handleRejection"
                name="Handle Rejection"
                isExecutable="true"
                camunda:historyTimeToLive="180">

    <bpmn:startEvent id="startEvent_rejectionStarted" name="Rejection started">
      <bpmn:outgoing>Flow_start_to_revoke</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sequenceFlow id="Flow_start_to_revoke"
                       sourceRef="startEvent_rejectionStarted"
                       targetRef="serviceTask_revokeClaim"/>

    <bpmn:serviceTask id="serviceTask_revokeClaim"
                      name="Revoke claim"
                      camunda:delegateExpression="#{revokeClaimDelegate}">
      <bpmn:incoming>Flow_start_to_revoke</bpmn:incoming>
      <bpmn:outgoing>Flow_revoke_to_rejection_mail</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="Flow_revoke_to_rejection_mail"
                       sourceRef="serviceTask_revokeClaim"
                       targetRef="serviceTask_sendRejectionMail"/>

    <bpmn:serviceTask id="serviceTask_sendRejectionMail"
                      name="Send Rejection Mail"
                      camunda:delegateExpression="#{sendRejectionMailDelegate}">
      <bpmn:incoming>Flow_revoke_to_rejection_mail</bpmn:incoming>
      <bpmn:outgoing>Flow_rejection_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="Flow_rejection_to_end"
                       sourceRef="serviceTask_sendRejectionMail"
                       targetRef="endEvent_rejectionHandled"/>

    <bpmn:endEvent id="endEvent_rejectionHandled" name="Rejection handled">
      <bpmn:incoming>Flow_rejection_to_end</bpmn:incoming>
    </bpmn:endEvent>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_rejection">
    <bpmndi:BPMNPlane id="BPMNPlane_rejection" bpmnElement="handleRejection">
      <bpmndi:BPMNShape id="startEvent_rejectionStarted_di" bpmnElement="startEvent_rejectionStarted">
        <dc:Bounds x="152" y="82" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="128" y="125" width="84" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="serviceTask_revokeClaim_di" bpmnElement="serviceTask_revokeClaim">
        <dc:Bounds x="250" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="serviceTask_sendRejectionMail_di" bpmnElement="serviceTask_sendRejectionMail">
        <dc:Bounds x="410" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endEvent_rejectionHandled_di" bpmnElement="endEvent_rejectionHandled">
        <dc:Bounds x="572" y="82" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="548" y="125" width="84" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_to_revoke_di" bpmnElement="Flow_start_to_revoke">
        <di:waypoint x="188" y="100"/><di:waypoint x="250" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_revoke_to_rejection_mail_di" bpmnElement="Flow_revoke_to_rejection_mail">
        <di:waypoint x="350" y="100"/><di:waypoint x="410" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_rejection_to_end_di" bpmnElement="Flow_rejection_to_end">
        <di:waypoint x="510" y="100"/><di:waypoint x="572" y="100"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
